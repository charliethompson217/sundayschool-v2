# ── Required ──────────────────────────────────────────────────────────────────

# local
NFL_NOTIFY_URL=https://<ingest-api-url>/internal/espn-ingest
NFL_WEBHOOK_SECRET=<webhook-secret>

# development
# NFL_NOTIFY_URL=https://<ingest-api-url>/internal/espn-ingest
# NFL_WEBHOOK_SECRET=<webhook-secret>

# staging
# NFL_NOTIFY_URL=https://<ingest-api-url>/internal/espn-ingest
# NFL_WEBHOOK_SECRET=<webhook-secret>

# production
# NFL_NOTIFY_URL=https://<ingest-api-url>/internal/espn-ingest
# NFL_WEBHOOK_SECRET=<webhook-secret>

# ── General ───────────────────────────────────────────────────────────────────

NFL_LOG_LEVEL=INFO
NFL_DB_FILE=nfl_state.db
NFL_HTTP_TIMEOUT_SECS=10
NFL_SCHEDULE_REFRESH_SECS=86400
NFL_MAX_IDLE_SLEEP_SECS=1800

# ── Polling concurrency ───────────────────────────────────────────────────────

NFL_POLL_WORKERS=4
NFL_MAX_POLLS_PER_CYCLE=12
NFL_POLL_JITTER_SECS=2

# ── Pre-kickoff intervals ─────────────────────────────────────────────────────

NFL_PRE_KICKOFF_WATCH_SECS=1800
NFL_PRE_KICKOFF_POLL_SECS=600
NFL_PRE_KICKOFF_NEAR_SECS=300
NFL_PRE_KICKOFF_NEAR_POLL_SECS=120

# ── In-game intervals ─────────────────────────────────────────────────────────

NFL_IN_PROGRESS_POLL_SECS=300
NFL_HALFTIME_POLL_SECS=180
NFL_LATE_GAME_POLL_SECS=120
NFL_FINAL_WINDOW_POLL_SECS=30
NFL_OT_POLL_SECS=60
NFL_OT_FINAL_WINDOW_POLL_SECS=20

# ── Expected game duration ────────────────────────────────────────────────────

NFL_EXPECTED_GAME_DURATION_SECS=12000
NFL_EXPECTED_END_TIGHTEN_SECS=900
NFL_PAST_EXPECTED_END_POLL_SECS=30

# ── Webhook retry / backoff ───────────────────────────────────────────────────

NFL_MAX_WEBHOOK_RETRIES=5
NFL_WEBHOOK_BACKOFF_BASE_SECS=30
NFL_WEBHOOK_BACKOFF_MAX_SECS=1800
NFL_WEBHOOK_PERMANENT_BACKOFF_SECS=14400
NFL_WEBHOOK_BATCH_SIZE=50
WEBHOOK_TIMEOUT_SECS=60
